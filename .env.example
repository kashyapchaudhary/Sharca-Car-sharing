# Sharca - Environment Variables
# Copy this file to .env and fill in your values.
# NOTE: These are PUBLIC/publishable keys for a frontend-only app.
# They are safe to use client-side but should NOT be secret keys.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
